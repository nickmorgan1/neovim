#!/usr/bin/env bash
# Prints fzf --color args matching the current macOS appearance
# (Catppuccin Latte for light, Frappe for dark), so fzf's own
# highlight colors don't clash with the tmux popup background.

if [[ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" == "Dark" ]]; then
    # Catppuccin Frappe
    echo "--color=bg+:#414559,bg:#303446,spinner:#f2d5cf,hl:#e78284" \
         "--color=fg:#c6d0f5,header:#e78284,info:#ca9ee6,pointer:#f2d5cf" \
         "--color=marker:#babbf1,fg+:#c6d0f5,prompt:#ca9ee6,hl+:#e78284" \
         "--color=selected-bg:#51576d" \
         "--color=border:#414559,label:#c6d0f5"
else
    # Catppuccin Latte
    echo "--color=bg+:#ccd0da,bg:#eff1f5,spinner:#dc8a78,hl:#d20f39" \
         "--color=fg:#4c4f69,header:#d20f39,info:#8839ef,pointer:#dc8a78" \
         "--color=marker:#dc8a78,fg+:#4c4f69,prompt:#8839ef,hl+:#d20f39" \
         "--color=selected-bg:#bcc0cc" \
         "--color=border:#ccd0da,label:#4c4f69"
fi
